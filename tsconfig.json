{
  "compilerOptions": {
    "moduleResolution": "bundler",
    "module": "esnext",
    "target": "esnext",
    "checkJs": true,
    "strict": true,
    "allowJs": true,
    "noEmit": true,
    "isolatedModules": true,
    "noImplicitAny": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true
  },
  "include": ["eslint.config.js", "ESLint/**/*.js", "**/*.ts", "**/*.svelte"],
  "exclude": ["node_modules"]
}
